# WalletConnect Project ID — required for wallet connection UI
# Public key by design (WalletConnect requires it client-side)
# Get one free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Backend API base URL — server-side only, used in Next.js API routes
BACKEND_URL=http://localhost:3001
