PORT=3001
NODE_ENV=development

# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:3000

# Reloadly — card fulfillment (virtual Visa + gift cards)
# https://www.reloadly.com/developers
RELOADLY_CLIENT_ID=
RELOADLY_CLIENT_SECRET=
RELOADLY_ENV=sandbox

# Base chain RPC — Alchemy recommended (webhook support)
ALCHEMY_API_KEY=
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Hot wallet — the address users send USDC / $USDTB to
PAYMENT_WALLET_ADDRESS=

# $USDTB token contract address on Base
USDTB_TOKEN_ADDRESS=

# USDC on Base mainnet (this is the canonical address, public)
USDC_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Email delivery via SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=cards@usdtb.us

# Internal secret for signing session tokens
JWT_SECRET=
